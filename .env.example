# Copie este arquivo para .env e ajuste as URLs.
# Vite/WXT injetam estas variaveis em tempo de BUILD: apos editar, rode npm run build (ou npm run dev).

# URL base da API do backend (Laravel). As rotas da API ficam sob /api.
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# URL base do app web (links de cadastro, recuperar senha, detalhes de processo/pessoa).
# Precisa terminar com barra.
VITE_APP_BASE_URL=http://127.0.0.1:8000/
